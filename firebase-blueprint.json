{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents an item in the store inventory.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product." },
        "category": { "type": "string", "description": "The category of the product." },
        "quantity": { "type": "number", "description": "The current stock quantity." },
        "purchasePrice": { "type": "number", "description": "The price at which the product was bought." },
        "sellingPrice": { "type": "number", "description": "The price at which the product is sold." },
        "expiryDate": { "type": "string", "format": "date", "description": "The expiration date of the product." },
        "supplierName": { "type": "string", "description": "The name of the supplier." },
        "barcode": { "type": "string", "description": "The barcode of the product (optional)." },
        "lowStockThreshold": { "type": "number", "description": "The threshold for low stock alerts." },
        "userId": { "type": "string", "description": "The ID of the shopkeeper who owns this product." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the product was added." }
      },
      "required": ["name", "category", "quantity", "purchasePrice", "sellingPrice", "userId", "createdAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Represents a product sale transaction.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "The ID of the product sold." },
        "productName": { "type": "string", "description": "The name of the product sold." },
        "quantity": { "type": "number", "description": "The quantity sold." },
        "sellingPrice": { "type": "number", "description": "The price at which the product was sold." },
        "totalPrice": { "type": "number", "description": "The total price of the sale (quantity * sellingPrice)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "The timestamp of the sale." },
        "userId": { "type": "string", "description": "The ID of the shopkeeper who made the sale." }
      },
      "required": ["productId", "productName", "quantity", "sellingPrice", "totalPrice", "timestamp", "userId"]
    },
    "User": {
      "title": "User",
      "description": "Represents a shopkeeper user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the shopkeeper." },
        "email": { "type": "string", "format": "email", "description": "The email of the shopkeeper." },
        "role": { "type": "string", "enum": ["admin"], "description": "The role of the user (default: admin)." },
        "shopName": { "type": "string", "description": "The name of the shop." }
      },
      "required": ["name", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Collection of products in the store." },
    "/sales/{saleId}": { "schema": "Sale", "description": "Collection of sales transactions." },
    "/users/{userId}": { "schema": "User", "description": "Collection of shopkeeper user profiles." }
  }
}
